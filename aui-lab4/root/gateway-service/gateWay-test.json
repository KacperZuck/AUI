{
  "info": {
    "name": "Gateway Tests Dynamic",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create New Element",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Element1\",\n  \"description\": \"Opis elementu\",\n  \"value\": 123\n}"
        },
        "url": {
          "raw": "http://localhost:8080/elements",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["elements"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Pobierz ID nowo utworzonego elementu i zapisz w zmiennej kolekcji",
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set(\"elementId\", jsonData.id);",
              "console.log(\"elementId set to: \" + jsonData.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Element by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/elements/{{elementId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["elements", "{{elementId}}"]
        }
      }
    },
    {
      "name": "Update Element",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Element1 Updated\",\n  \"description\": \"Zaktualizowany opis\",\n  \"value\": 456\n}"
        },
        "url": {
          "raw": "http://localhost:8080/elements/{{elementId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["elements", "{{elementId}}"]
        }
      }
    },
    {
      "name": "Delete Element",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8080/elements/{{elementId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["elements", "{{elementId}}"]
        }
      }
    },
    {
      "name": "Get All Elements",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/elements",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["elements"]
        }
      }
    },
    {
      "name": "Search Elements by Name",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:8080/elements/search?name=Element1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["elements", "search"],
          "query": [
            {
              "key": "name",
              "value": "Element1"
            }
          ]
        }
      }
    }
  ]
}
